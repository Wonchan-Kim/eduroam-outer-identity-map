<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="ufscar.br" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>21</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>eduroam.ufscar.br</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@ufscar.br</OuterIdentity>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <NonEAPAuthMethod>
            <Type>1</Type>
          </NonEAPAuthMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <SSID>DCAm</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>UFSCar – Universidade Federal de São Carlos - DCAm</DisplayName>
      <Description>Perfil exclusivo para Servidores do DCAm. Permite acesso à rede interna do DCAm quando o usuário estiver dentro das dependências do DCAm.</Description>
      <ProviderLocation>
        <Longitude>-47.913298999999995</Longitude>
        <Latitude>-21.9824687</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/svg+xml" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <WebAddress>https://servicos.ufscar.br</WebAddress>
        <Phone>(16) 3351-8150</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
