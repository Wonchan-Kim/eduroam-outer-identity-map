<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="ubishops.ca" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>*.ubishops.ca</ServerID>
          <ServerID>bu-clrpass.ubishops.ca</ServerID>
          <ServerID>bu-clrpass01.ubishops.ca</ServerID>
          <ServerID>bu-clrpass02.ubishops.ca</ServerID>
          <ServerID>clearpass.ubishops.ca</ServerID>
          <ServerID>radius.ubishops.ca</ServerID>
          <ServerID>ubishops.ca</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>ubishops.ca</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <SSID>WIZABU</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Bishop's University - EDUROAM and WIZABU on personal device</DisplayName>
      <Description>Select this option to configure your personal device for EDUROAM and WIZABU wifi networks.
NOTE: Use your Bishop's e-mail address and your Bishop's password as your credentials.</Description>
      <ProviderLocation>
        <Longitude>-71.8466886</Longitude>
        <Latitude>45.364536</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>helpdesk@ubishops.ca</EmailAddress>
        <WebAddress>https://www.ubishops.ca/information-technology-services</WebAddress>
        <Phone>819-822-9600 ext. 2273</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
