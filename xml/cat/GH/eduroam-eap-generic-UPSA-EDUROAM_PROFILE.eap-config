<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="upsa.edu.gh" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>21</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius1.upsa.edu.gh</ServerID>
          <ServerID>radius2.upsa.edu.gh</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>upsa.edu.gh</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <NonEAPAuthMethod>
            <Type>1</Type>
          </NonEAPAuthMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>University of Professional Studies, Accra</DisplayName>
      <Description>This configuration profile is designed exclusively for the staff of UNIVERSITY OF PROFESSIONAL STUDIES, ACCRA; to facilitate automatic and secure connection to the eduroam wireless network. It ensures compliant network settings and enhanced security protocols tailored to the specific needs and access privileges of university staff members. Please install this profile only if you are a current staff member of UPSA.</Description>
      <ProviderLocation>
        <Longitude>-0.1664195</Longitude>
        <Latitude>5.6618149</Latitude>
      </ProviderLocation>
      <ProviderLocation>
        <Longitude>-1.0800271</Longitude>
        <Latitude>8.0300284</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>helpdesk@upsamail.edu.gh</EmailAddress>
        <Phone>0539928940</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
