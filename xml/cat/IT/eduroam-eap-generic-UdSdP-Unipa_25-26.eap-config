          <ServerID>wifi.unipa.it</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@unipa.it</OuterIdentity>
          <InnerIdentitySuffix>unipa.it</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
