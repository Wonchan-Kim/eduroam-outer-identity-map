          <ServerID>aubnac01.aub.ac.uk</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>aub.ac.uk</InnerIdentitySuffix>
        </ClientSideCredential>
