          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>login.franklinpierce.edu</ServerID>
          <ServerID>login1.franklinpierce.edu</ServerID>
          <ServerID>login2.franklinpierce.edu</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>franklinpierce.edu</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
