<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="hs-bochum.de" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>21</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>rad01.hs-bochum.de</ServerID>
          <ServerID>rad02.hs-bochum.de</ServerID>
          <ServerID>rad11.hs-bochum.de</ServerID>
          <ServerID>rad12.hs-bochum.de</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@hs-bochum.de</OuterIdentity>
          <InnerIdentitySuffix>hs-bochum.de</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
