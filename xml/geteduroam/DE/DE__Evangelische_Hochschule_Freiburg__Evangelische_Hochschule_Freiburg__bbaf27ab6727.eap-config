<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="radius.eh-freiburg.de" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>21</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius.eh-freiburg.de</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>radius.eh-freiburg.de</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <NonEAPAuthMethod>
            <Type>1</Type>
          </NonEAPAuthMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Evangelische Hochschule Freiburg</DisplayName>
      <Description>Eduroam Profil der evangelischen Hochschule Freiburg</Description>
      <ProviderLocation>
        <Longitude>7.803577799999971</Longitude>
        <Latitude>47.99742310000001</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
