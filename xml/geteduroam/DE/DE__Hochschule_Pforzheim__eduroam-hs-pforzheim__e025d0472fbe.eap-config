<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="hs-pforzheim.de" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>checkpoint.hs-pforzheim.de</ServerID>
        </ServerSideCredential>
        <ClientSideCredential/>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Hochschule Pforzheim</DisplayName>
      <Description>Eduroam-Einwahl der Hochschule Pforzheim</Description>
      <ProviderLocation>
        <Longitude>8.717305973815882</Longitude>
