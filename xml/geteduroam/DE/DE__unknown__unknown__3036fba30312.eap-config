<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="htwg-konstanz.de" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>eduroam.htwg-konstanz.de</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@htwg-konstanz.de</OuterIdentity>
          <InnerIdentitySuffix>htwg-konstanz.de</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>HTWG Hochschule Konstanz University of Applied Sciences - eduroam</DisplayName>
      <Description>Default settings to connect yourself with eduroam. These settings only work for members of the HTWG Konstanz University of Applied Sciences.</Description>
      <ProviderLocation>
        <Longitude>9.170920971411078</Longitude>
        <Latitude>47.66722853633105</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>eduroam@htwg-konstanz.de</EmailAddress>
        <WebAddress>https://www.htwg-konstanz.de/rz</WebAddress>
        <Phone>+49 7531 206 148</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
