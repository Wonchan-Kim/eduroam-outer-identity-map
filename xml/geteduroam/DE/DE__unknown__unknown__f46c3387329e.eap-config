<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="uni-koblenz.de" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius.uni-koblenz.de</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>eduroam@uni-koblenz.de</OuterIdentity>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Universität Koblenz</DisplayName>
      <Description>Wireless access at all participating educational federations.</Description>
      <ProviderLocation>
        <Longitude>7.560066499999948</Longitude>
        <Latitude>50.364362</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>support@uni-koblenz.de</EmailAddress>
        <WebAddress>https://www.uni-koblenz.de/de/zimt/services/wlan</WebAddress>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
