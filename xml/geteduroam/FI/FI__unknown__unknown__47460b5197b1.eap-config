<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="abo.fi" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius-auth1.abo.fi</ServerID>
          <ServerID>radius-auth2.abo.fi</ServerID>
          <ServerID>radius.abo.fi</ServerID>
          <ServerID>radius2.abo.fi</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@abo.fi</OuterIdentity>
          <InnerIdentitySuffix>abo.fi</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Åbo Akademi University - Åbo Akademi</DisplayName>
      <Description>Åbo Akademi personal och studerande.</Description>
      <ProviderLocation>
        <Longitude>21.600983199999973</Longitude>
        <Latitude>63.0984119</Latitude>
      </ProviderLocation>
      <ProviderLocation>
        <Longitude>22.278222400000004</Longitude>
        <Latitude>60.4507664</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
