<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="univ-angers.fr" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>21</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>rad01.univ-angers.fr</ServerID>
          <ServerID>rad02.univ-angers.fr</ServerID>
          <ServerID>radius.univ-angers.fr</ServerID>
          <ServerID>radiusqual.univ-angers.fr</ServerID>
          <ServerID>repradius.univ-angers.fr</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonyme@univ-angers.fr</OuterIdentity>
          <InnerIdentitySuffix>univ-angers.fr</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <NonEAPAuthMethod>
            <Type>1</Type>
          </NonEAPAuthMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
