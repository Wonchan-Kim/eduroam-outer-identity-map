    <ProviderInfo>
      <DisplayName>Université d'Angers - </DisplayName>
      <Description>Profile for students and staff of the University of Angers(FR)</Description>
      <ProviderLocation>
        <Longitude>-0.5495591000000104</Longitude>
        <Latitude>47.477028</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
