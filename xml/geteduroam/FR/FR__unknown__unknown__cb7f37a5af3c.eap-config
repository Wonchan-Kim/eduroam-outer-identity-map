          <ServerID>auth.u-strasbg.fr</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@unistra.fr</OuterIdentity>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
