<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="atu.edu.gh" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius1.atu.edu.gh</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>atu.edu.gh</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Accra Technical University</DisplayName>
      <Description>This configuration profile is designed exclusively for the staff of Accra Technical University Community to facilitate automatic and secure connection to the eduroam wireless network. It ensures compliant network settings and enhanced security protocols tailored to the specific needs and access privileges of university staff and student members. Please install this profile only if you are a current staff or student of ATU.</Description>
      <ProviderLocation>
        <Longitude>-0.20520374178886414</Longitude>
        <Latitude>5.554247164602444</Latitude>
      </ProviderLocation>
      <ProviderLocation>
        <Longitude>-0.20522385835647583</Longitude>
        <Latitude>5.554226786538251</Latitude>
      </ProviderLocation>
      <ProviderLocation>
        <Longitude>-1.0800271</Longitude>
        <Latitude>8.0300284</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>helpdesk@atu.edu.gh</EmailAddress>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
