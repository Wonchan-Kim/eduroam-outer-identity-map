<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="tu.edu.np" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>Eduroam Server Certificate</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@tu.edu.np</OuterIdentity>
          <InnerIdentitySuffix>tu.edu.np</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
      <IEEE8023/>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Tribhuvan University</DisplayName>
      <Description>Eduroam connection for users, visitors, students, and faculty in Tribhuwan University</Description>
      <ProviderLocation>
        <Longitude>85.2871529</Longitude>
        <Latitude>27.6812723</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/gif" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>eduroam@tu.edu.np</EmailAddress>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
