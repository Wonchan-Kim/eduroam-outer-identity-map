      <Description>eduroam UA Configuration for all users</Description>
      <ProviderLocation>
        <Longitude>-8.658024399999931</Longitude>
        <Latitude>40.6310452</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
