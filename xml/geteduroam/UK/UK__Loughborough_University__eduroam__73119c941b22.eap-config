<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="lboro.ac.uk" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius.lboro.ac.uk</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>@lboro.ac.uk</OuterIdentity>
          <InnerIdentitySuffix>lboro.ac.uk</InnerIdentitySuffix>
          <InnerIdentityHint>true</InnerIdentityHint>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
      <IEEE8023/>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Loughborough University</DisplayName>
      <Description>Loughborough University eduroam configuration</Description>
      <ProviderLocation>
        <Longitude>-1.2294742999999926</Longitude>
        <Latitude>52.7648728</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>it.services@lboro.ac.uk</EmailAddress>
        <WebAddress>https://www.lboro.ac.uk/services/it/getting-online/</WebAddress>
        <Phone>https://www.lboro.ac.uk/services/it/</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
