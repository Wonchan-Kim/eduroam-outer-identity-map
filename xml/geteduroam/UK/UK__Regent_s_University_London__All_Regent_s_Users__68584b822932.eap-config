      <ProviderLocation>
        <Longitude>-0.15566061957304586</Longitude>
        <Latitude>51.525563064795705</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <EmailAddress>servicedesk@regents.ac.uk</EmailAddress>
        <Phone>+ 44 (0) 207 487 7479</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
