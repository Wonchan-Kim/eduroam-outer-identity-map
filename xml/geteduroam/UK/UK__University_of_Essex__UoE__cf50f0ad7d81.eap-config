          <ServerID>eduroam.essex.ac.uk</ServerID>
          <ServerID>guestportal.essex.ac.uk</ServerID>
          <ServerID>guestportala.essex.ac.uk</ServerID>
          <ServerID>guestportalb.essex.ac.uk</ServerID>
