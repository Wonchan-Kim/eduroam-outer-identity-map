          <CA format="X.509" encoding="base64"></CA>
          <ServerID>radius.gla.ac.uk</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <OuterIdentity>anonymous@glasgow.ac.uk</OuterIdentity>
          <InnerIdentitySuffix>glasgow.ac.uk</InnerIdentitySuffix>
