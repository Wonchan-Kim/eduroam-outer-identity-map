<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="wlv.ac.uk" namespace="urn:RFC4282:realm">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>nap.unv.wlv.ac.uk</ServerID>
          <ServerID>nap1.unv.wlv.ac.uk</ServerID>
          <ServerID>nap2.unv.wlv.ac.uk</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>wlv.ac.uk</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>University of Wolverhampton</DisplayName>
      <Description>Use your University email address and password to log on</Description>
      <ProviderLocation>
        <Longitude>-2.1272888999999395</Longitude>
        <Latitude>52.5914939</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/png" encoding="base64"></ProviderLogo>
      <Helpdesk>
        <WebAddress>https://www.wlv.ac.uk/its/self-help/wireless-networks/</WebAddress>
        <Phone>+44(0)1902 322000</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
