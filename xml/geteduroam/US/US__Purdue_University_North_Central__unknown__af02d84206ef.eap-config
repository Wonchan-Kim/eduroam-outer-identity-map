<?xml version="1.0" encoding="UTF-8"?>
<EAPIdentityProviderList xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="eap-metadata.xsd">
  <EAPIdentityProvider version="1" lang="en" ID="undefined" namespace="urn:undefined">
    <AuthenticationMethods>
      <AuthenticationMethod>
        <EAPMethod>
          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>eduroam.pnc.edu</ServerID>
        </ServerSideCredential>
        <ClientSideCredential/>
        <InnerAuthenticationMethod>
          <EAPMethod>
            <Type>26</Type>
          </EAPMethod>
        </InnerAuthenticationMethod>
      </AuthenticationMethod>
    </AuthenticationMethods>
    <CredentialApplicability>
      <IEEE80211>
        <SSID>eduroam</SSID>
        <MinRSNProto>CCMP</MinRSNProto>
      </IEEE80211>
      <IEEE80211>
        <ConsortiumOID>001bc50460</ConsortiumOID>
      </IEEE80211>
    </CredentialApplicability>
    <ProviderInfo>
      <DisplayName>Purdue University North Central</DisplayName>
      <Description>This will install the Purdue University North Central eduroam wireless profile.</Description>
      <ProviderLocation>
        <Longitude>-86.89370079999998</Longitude>
        <Latitude>41.5844119</Latitude>
      </ProviderLocation>
      <ProviderLogo mime="image/svg+xml" encoding="base64"></ProviderLogo>
      <TermsOfUse><![CDATA[Using eduroam wireless will allow you to use your PNC login credentials to gain wireless access at other universities and organizations that provide eduroam wireless.

This will gain you Internet access at other locations. If you need to do sensitive work when at other locations use the PNC VPN after connecting to the eduroam wireless.

The username for eduroam will be your PNC username plus @pnc.edu. This is not your email address in cases where email is different from your username. Do not forget the @pnc.edu after the username or eduroam will not work.
]]></TermsOfUse>
      <Helpdesk>
        <EmailAddress>helpdesk@pnc.edu</EmailAddress>
        <WebAddress>www.pnc.edu</WebAddress>
        <Phone>219-785-5511</Phone>
      </Helpdesk>
    </ProviderInfo>
  </EAPIdentityProvider>
</EAPIdentityProviderList>
