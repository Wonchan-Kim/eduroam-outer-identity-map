          <Type>25</Type>
        </EAPMethod>
        <ServerSideCredential>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <CA format="X.509" encoding="base64"></CA>
          <ServerID>securelogin.net.oit.ohio.edu</ServerID>
        </ServerSideCredential>
        <ClientSideCredential>
          <InnerIdentitySuffix>ohio.edu</InnerIdentitySuffix>
        </ClientSideCredential>
        <InnerAuthenticationMethod>
